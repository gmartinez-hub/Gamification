{
  "name": "gravedad-zero-v2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build && node scripts/copy-runtime-assets.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa:headless": "node tools/gravedad-zero-closing-qa-cdp.mjs",
    "qa:release": "npm run typecheck && npm run test && npm run build && npm run qa:headless",
    "v4:installed": "node -e \"console.log('GRAVEDAD ZERO V4 instalado')\""
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "three": "^0.180.0"
  }
}
