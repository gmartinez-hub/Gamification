{
  "version": "robot-companion-states-v1",
  "defaultState": "idle",
  "assets": {
    "idle": "assets/ui/robot_companion/robot_idle.png",
    "ready": "assets/ui/robot_companion/robot_ready.png",
    "alert": "assets/ui/robot_companion/robot_alert.png",
    "stage_clear": "assets/ui/robot_companion/robot_stage_clear.png",
    "hint": "assets/ui/robot_companion/robot_hint.png",
    "shadow": "assets/ui/robot_companion/robot_shadow.png",
    "glow_cyan": "assets/ui/robot_companion/robot_glow_cyan.png",
    "glow_magenta": "assets/ui/robot_companion/robot_glow_magenta.png"
  },
  "states": {
    "idle": {
      "asset": "idle",
      "bob": true,
