      "message": "OBSTÁCULO DETECTADO"
    },
    "hint": {
      "asset": "hint",
      "bob": true,
      "glow": "cyan",
      "message": "TOCA EL COMPANION PARA VER OBJETIVOS"
    },
    "stage_clear": {
      "asset": "stage_clear",
      "bob": true,
      "glow": "cyan_magenta",
      "message": "STAGE UNLOCKED"
    }
  }
}